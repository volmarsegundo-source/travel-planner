# ============================================================
# TRAVEL PLANNER — Environment Variables Template
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# ----- DATABASE -----
# Local: postgresql://travel_planner:local_dev_password_not_secret@localhost:5432/travel_planner_dev
# Staging/Prod: provided by Railway/Render — get from team vault
DATABASE_URL="postgresql://travel_planner:local_dev_password_not_secret@localhost:5432/travel_planner_dev"

# ----- REDIS -----
# Local: redis://localhost:6379
# Staging/Prod: Upstash Redis URL (from Upstash dashboard)
REDIS_URL="redis://localhost:6379"

# Redis host/port (used by ioredis client in src/server/cache/redis.ts)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Upstash REST API (required for production Upstash client)
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# ----- AUTH.JS (NextAuth v5) -----
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_minimum_32_characters_long_here_ok"
NEXTAUTH_SECRET="same_as_AUTH_SECRET"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers — register apps in Google Cloud Console
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Apple OAuth (optional)
# APPLE_ID="YOUR_APPLE_SERVICE_ID"
# APPLE_SECRET="YOUR_APPLE_SECRET"

# ----- MAPBOX -----
# Public token (safe in client bundle — prefix NEXT_PUBLIC_)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.YOUR_MAPBOX_PUBLIC_TOKEN"
# Secret token (server-side geocoding API — NEVER expose to client)
MAPBOX_SECRET_TOKEN="sk.YOUR_MAPBOX_SECRET_TOKEN"

# ----- ANTHROPIC (Claude AI) -----
# Get your key at: https://console.anthropic.com/
# Optional: required only if using Claude as AI provider
ANTHROPIC_API_KEY="sk-ant-YOUR_ANTHROPIC_API_KEY"

# ----- GOOGLE AI (Gemini) -----
# Get your key at: https://aistudio.google.com/apikey
# Optional: required only if using Gemini as AI provider
# GOOGLE_AI_API_KEY="YOUR_GOOGLE_AI_API_KEY"

# ----- AI PROVIDER SELECTION -----
# Strategy: Gemini as primary (cost-effective), Anthropic as fallback (quality).
# Gemini 2.0 Flash is free-tier eligible and handles most expedition phases well.
# If Gemini fails (rate limit, timeout), falls back to Claude automatically.
AI_PROVIDER="gemini"
AI_FALLBACK_PROVIDER="anthropic"

# ----- UNSPLASH (destination images) -----
# Get from: https://unsplash.com/oauth/applications
# UNSPLASH_ACCESS_KEY="YOUR_UNSPLASH_ACCESS_KEY"

# ----- SENTRY -----
SENTRY_DSN="https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID"
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID"
SENTRY_AUTH_TOKEN="YOUR_SENTRY_AUTH_TOKEN"

# ----- ENCRYPTION -----
# 32-byte key in hex (64 hex chars). Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-64-hex-char-key-here-replace-me-0123456789abcdef1234abcd"

# ----- APP -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ----- VALIDATION SKIP (CI use only) -----
# SKIP_ENV_VALIDATION="true"
