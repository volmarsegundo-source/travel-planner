{
  "dataset_id": "dashboard-quickaccess",
  "version": "1.0.0",
  "sprint": 31,
  "spec_ref": "SPEC-QA-007",
  "description": "Eval cases for dashboard quick-access link visibility based on phase completion state",
  "grader": "link-visibility-correctness",
  "cases": [
    {
      "case_id": "QA-001",
      "title": "Full expedition (all 6 phases complete): all quick-access links visible",
      "input": {
        "trip": {
          "phase_3_checklist_count": 8,
          "phase_5_status": "completed",
          "phase_6_status": "completed"
        }
      },
      "expected": {
        "ver_checklist_visible": true,
        "ver_guia_visible": true,
        "ver_roteiro_visible": true,
        "gerar_relatorio_enabled": true
      }
    },
    {
      "case_id": "QA-002",
      "title": "Phases 1-3 only: only checklist link visible, report disabled",
      "input": {
        "trip": {
          "phase_3_checklist_count": 5,
          "phase_5_status": "not_started",
          "phase_6_status": "not_started"
        }
      },
      "expected": {
        "ver_checklist_visible": true,
        "ver_guia_visible": false,
        "ver_roteiro_visible": false,
        "gerar_relatorio_enabled": false
      }
    },
    {
      "case_id": "QA-003",
      "title": "Phase 1 only (new expedition): no quick-access links",
      "input": {
        "trip": {
          "phase_3_checklist_count": 0,
          "phase_5_status": "not_started",
          "phase_6_status": "not_started"
        }
      },
      "expected": {
        "ver_checklist_visible": false,
        "ver_guia_visible": false,
        "ver_roteiro_visible": false,
        "gerar_relatorio_enabled": false
      }
    },
    {
      "case_id": "QA-004",
      "title": "Phases 3+5 complete but not 6: report disabled",
      "input": {
        "trip": {
          "phase_3_checklist_count": 10,
          "phase_5_status": "completed",
          "phase_6_status": "active"
        }
      },
      "expected": {
        "ver_checklist_visible": true,
        "ver_guia_visible": true,
        "ver_roteiro_visible": false,
        "gerar_relatorio_enabled": false,
        "note": "Report requires ALL of phases 3+5+6 complete"
      }
    },
    {
      "case_id": "QA-005",
      "title": "Phases 3+6 complete but not 5: report disabled",
      "input": {
        "trip": {
          "phase_3_checklist_count": 6,
          "phase_5_status": "active",
          "phase_6_status": "completed"
        }
      },
      "expected": {
        "ver_checklist_visible": true,
        "ver_guia_visible": false,
        "ver_roteiro_visible": true,
        "gerar_relatorio_enabled": false,
        "note": "Missing phase 5 blocks report generation"
      }
    },
    {
      "case_id": "QA-006",
      "title": "BOLA: quick-access links not accessible cross-user",
      "input": {
        "requesting_user": "user-B",
        "trip_owner": "user-A",
        "trip": {
          "phase_3_checklist_count": 10,
          "phase_5_status": "completed",
          "phase_6_status": "completed"
        }
      },
      "expected": {
        "response_status": 403,
        "ver_checklist_visible": false,
        "ver_guia_visible": false,
        "ver_roteiro_visible": false,
        "gerar_relatorio_enabled": false
      }
    }
  ]
}
