      "id": "GA-001",
      "description": "Guia para Tokyo, Japao em ingles -- verifica precisao factual de dados basicos",
      "input": {
        "destination": "Tokyo, Japan",
        "language": "en"
      },
      "expected": {
        "all_10_sections_present": true,
        "language": "en",
        "stat_sections_have_type_stat": true,
        "content_sections_have_type_content": true,
        "content_sections_have_details": true,
        "factual_checks": {
          "timezone": "JST or UTC+9 or GMT+9",
          "currency": "JPY or Japanese Yen",
          "language": "Japanese",
          "electricity": "100V or Type A or Type B"
