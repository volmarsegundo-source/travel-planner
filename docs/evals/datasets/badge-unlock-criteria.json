      "expected": { "badge_unlocked": "multicontinental" },
      "grader": "code"
    },
    {
      "id": "BDG-014",
      "description": "fiel: 10+ daily logins",
      "input": { "event": "daily_login", "user_state": { "daily_login_count": 10 } },
      "expected": { "badge_unlocked": "fiel" },
      "grader": "code"
    },
    {
      "id": "BDG-015",
