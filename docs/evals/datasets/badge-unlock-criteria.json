      "id": "BDG-001",
      "description": "primeira_viagem: unlocks on first completed expedition",
      "input": { "event": "trip_complete", "user_state": { "completed_trips": 1 } },
      "expected": { "badge_unlocked": "primeira_viagem", "idempotent": true },
      "grader": "code"
    },
    {
      "id": "BDG-002",
      "description": "viajante_frequente: unlocks at 3 completed expeditions",
      "input": { "event": "trip_complete", "user_state": { "completed_trips": 3 } },
      "expected": { "badge_unlocked": "viajante_frequente" },
      "grader": "code"
    },
    {
      "id": "BDG-003",
      "description": "globetrotter: unlocks at 5 completed expeditions",
      "input": { "event": "trip_complete", "user_state": { "completed_trips": 5 } },
      "expected": { "badge_unlocked": "globetrotter" },
      "grader": "code"
    },
    {
      "id": "BDG-004",
      "description": "marco_polo: unlocks at 10 completed expeditions",
      "input": { "event": "trip_complete", "user_state": { "completed_trips": 10 } },
      "expected": { "badge_unlocked": "marco_polo" },
      "grader": "code"
    },
    {
      "id": "BDG-005",
      "description": "detalhista: all Phase 4 fields filled in one expedition",
