      "description": "solo_explorer: plan a solo trip (1 adult, 0 children)",
      "input": { "event": "trip_complete", "user_state": { "passengers": { "adults": 1, "children": 0, "infants": 0 } } },
      "expected": { "badge_unlocked": "solo_explorer" },
      "grader": "code"
    },
    {
      "id": "BDG-012",
