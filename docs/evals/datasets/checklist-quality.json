  "test_cases": [
    {
      "case_id": "CQ-001",
      "title": "International trip to UK: Guide digest triggers Type G adapter in checklist",
      "category": "itinerary_aware",
      "description": "TC-AI-005: When guide digest includes plugType=Type G (UK), checklist must suggest an electrical adapter.",
      "input": {
        "trip": {
          "destination": "London, United Kingdom",
          "startDate": "2026-07-10",
          "endDate": "2026-07-17",
          "tripType": "international",
          "passengers": { "adults": 2, "children": 0, "infants": 0 }
        },
        "guide_digest": {
          "climate": "Mild, 15-22°C in July",
          "plugType": "Type G, 230V",
          "currencyLocal": "GBP",
          "dialCode": "+44",
          "safetyLevel": "safe",
          "vaccinesRequired": "None required",
          "topCategories": ["History", "Museums", "Parks"]
        },
        "itinerary_digest": {
          "totalDays": 7,
          "activityTypesUsed": ["MUSEUM", "SIGHTSEEING", "WALKING_TOUR"],
          "hasBeachDay": false,
          "hasHikeDay": false,
          "hasNightlifeEvening": false,
          "hasReligiousSite": true,
          "hasMuseumDay": true,
          "highestIntensity": "moderate",
          "transitDaysCount": 0
        },
        "logistics_digest": {
          "transportModes": ["flight"],
          "accommodationTypes": ["hotel"],
          "mobility": ["tube", "walking", "taxi"],
          "hasRentalCar": false,
          "hasInternationalFlight": true
        }
      },
      "expected": {
        "must_include_category": "TECHNOLOGY",
        "must_include_items_matching": ["adapter", "adaptador", "Type G", "tomada"],
        "must_not_include": ["sunscreen", "protetor solar", "swimwear"],
        "rationale": "Type G plug in UK → adapter required. No beach day → no sunscreen."
      }
    },
