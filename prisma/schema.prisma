// This is your Prisma schema file
// Prisma 7: datasource url is configured in prisma.config.ts, not here
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js v5 required models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed — set for credentials provider, null for OAuth-only users
  locale        String    @default("pt-BR")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  trips     Trip[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Travel Planner domain models ──────────────────────────────────────────

enum TripStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TripVisibility {
  PRIVATE
  PUBLIC
  SHARED
}

enum TravelStyle {
  ADVENTURE
  CULTURE
  RELAXATION
  GASTRONOMY
}

model Trip {
  id                 String         @id @default(cuid())
  userId             String
  title              String
  destinationName    String
  destinationPlaceId String?
  startDate          DateTime?
  endDate            DateTime?
  travelers          Int            @default(1)
  travelStyle        TravelStyle?
  budgetTotal        Decimal?       @db.Decimal(12, 2)
  budgetCurrency     String         @default("BRL")
  coverGradient      String         @default("sunset")
  coverEmoji         String?
  status             TripStatus     @default(PLANNING)
  visibility         TripVisibility @default(PRIVATE)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  itineraryDays  ItineraryDay[]
  checklistItems ChecklistItem[]

  @@index([userId, deletedAt])
  @@index([userId, status])
}

enum ActivityType {
  ATTRACTION
  RESTAURANT
  TRANSPORT
  ACCOMMODATION
  FREE_TIME
  OTHER
}

model ItineraryDay {
  id        String     @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime?
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
}

model Activity {
  id            String       @id @default(cuid())
  dayId         String
  title         String
  description   String?
  location      String?
  startTime     String?
  endTime       String?
  estimatedCost Decimal?     @db.Decimal(10, 2)
  currency      String       @default("BRL")
  type          ActivityType @default(OTHER)
  orderIndex    Int          @default(0)
  externalUrl   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, orderIndex])
}

enum ChecklistCategory {
  DOCUMENTS
  HEALTH
  CURRENCY
  WEATHER
  TECHNOLOGY
  OTHER
}

model ChecklistItem {
  id            String            @id @default(cuid())
  tripId        String
  category      ChecklistCategory @default(OTHER)
  text          String
  isChecked     Boolean           @default(false)
  orderIndex    Int               @default(0)
  isAiGenerated Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, category])
}
