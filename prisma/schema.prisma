// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TripStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TripVisibility {
  PRIVATE
  PUBLIC
  SHARED
}

// ─── Auth.js required models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  passwordHash    String?
  preferredLocale String?   @default("pt-BR") @db.VarChar(10)
  role            String    @default("user") @db.VarChar(20)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deactivatedAt   DateTime?

  accounts          Account[]
  sessions          Session[]
  trips             Trip[]
  progress          UserProgress?
  badges            UserBadge[]
  pointTransactions PointTransaction[]
  profile           UserProfile?
  purchases         Purchase[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// ─── Trip ────────────────────────────────────────────────────────────────────

model Trip {
  id          String         @id @default(cuid())
  userId      String

  // Dados principais
  title       String         @db.VarChar(100)
  destination String         @db.VarChar(150)
  description String?        @db.VarChar(500)

  // Datas
  startDate   DateTime?
  endDate     DateTime?

  // Capa (v1: nome do gradiente + emoji — sem URL de imagem)
  coverGradient String       @default("sunset") @db.VarChar(50)
  coverEmoji    String       @default("✈️")    @db.VarChar(10)

  // Estado
  status      TripStatus     @default(PLANNING)
  visibility  TripVisibility @default(PRIVATE)

  // Timestamps
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  // Atlas Gamification
  expeditionMode Boolean        @default(true)
  currentPhase   Int            @default(1)
  tripType       String         @default("international") @db.VarChar(20)

  // Sprint 20: Passengers
  passengers     Json?

  // Sprint 20: Transport & Logistics
  origin         String?        @db.VarChar(150)
  localMobility  String[]       @default([])

  // Sprint 29: Map pin coordinates
  destinationLat Float?
  destinationLon Float?

  // Relacoes
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  itineraryDays     ItineraryDay[]
  checklist         ChecklistItem[]
  phases            ExpeditionPhase[]
  phaseChecklist    PhaseChecklistItem[]
  destinationGuide  DestinationGuide?
  itineraryPlan     ItineraryPlan?
  transportSegments TransportSegment[]
  accommodations    Accommodation[]

  // Indexes
  @@index([userId, deletedAt])
  @@index([userId, status, deletedAt])
  @@index([userId, startDate, deletedAt])
  @@map("trips")
}

// ─── ItineraryDay ─────────────────────────────────────────────────────────────

model ItineraryDay {
  id        String   @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime?
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
  @@map("itinerary_days")
}

// ─── Activity ─────────────────────────────────────────────────────────────────

model Activity {
  id           String   @id @default(cuid())
  dayId        String
  title        String   @db.VarChar(200)
  notes        String?  @db.Text
  startTime    String?  @db.VarChar(5)
  endTime      String?  @db.VarChar(5)
  orderIndex   Int      @default(0)
  activityType String?  @db.VarChar(50)

  // GPS coordinates (optional — populated by AI)
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, orderIndex])
  @@map("activities")
}

// ─── ChecklistItem ─────────────────────────────────────────────────────────────

model ChecklistItem {
  id       String  @id @default(cuid())
  tripId   String
  category String  @db.VarChar(50)
  label    String  @db.VarChar(200)
  checked  Boolean @default(false)
  orderIndex Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, category])
  @@map("checklist_items")
}

// ─── Atlas Gamification ─────────────────────────────────────────────────────

model UserProgress {
  id              String    @id @default(cuid())
  userId          String    @unique
  totalPoints     Int       @default(0)
  availablePoints Int       @default(500)
  currentRank     String    @default("traveler") @db.VarChar(50)
  streakDays      Int       @default(0)
  lastLoginDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_progress")
}

model ExpeditionPhase {
  id           String    @id @default(cuid())
  tripId       String
  phaseNumber  Int
  status       String    @default("locked") @db.VarChar(20)
  completedAt  DateTime?
  pointsEarned Int       @default(0)
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, phaseNumber])
  @@index([tripId])
  @@index([tripId, status])
  @@map("expedition_phases")
}

model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String   @db.VarChar(50)
  description String   @db.VarChar(255)
  tripId      String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([userId, type, tripId])
  @@map("point_transactions")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String   @db.VarChar(50)
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}

// ─── Phase Checklist Items (Phases 3/4/5) ─────────────────────────────────

model PhaseChecklistItem {
  id          String    @id @default(cuid())
  tripId      String
  phaseNumber Int
  itemKey     String    @db.VarChar(50)
  required    Boolean   @default(false)
  completed   Boolean   @default(false)
  deadline    DateTime?
  pointsValue Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, phaseNumber, itemKey])
  @@index([tripId, phaseNumber])
  @@map("phase_checklist_items")
}

// ─── User Profile (Progressive) ───────────────────────────────────────────

model UserProfile {
  userId              String    @id
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate           DateTime?
  phone               String?   @db.VarChar(20)
  country             String?   @db.VarChar(100)
  city                String?   @db.VarChar(100)
  address             String?   @db.VarChar(300)
  passportNumberEnc   String?   @db.Text
  passportExpiry      DateTime?
  nationalIdEnc       String?   @db.Text
  bio                 String?   @db.VarChar(500)
  dietaryRestrictions String?   @db.VarChar(300)
  accessibility       String?   @db.VarChar(300)
  preferences         Json?     @default("{}")
  completionScore     Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("user_profiles")
}

// ─── Destination Guide (Phase 5 — AI-generated) ──────────────────────────

model DestinationGuide {
  id              String   @id @default(cuid())
  tripId          String   @unique
  content         Json
  destination     String   @db.VarChar(200)
  locale          String   @db.VarChar(10)
  generationCount Int      @default(1)
  viewedSections  Json     @default("[]")
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("destination_guides")
}

// ─── Itinerary Plan (Phase 6 — AI-generated itinerary tracker) ───────────

model ItineraryPlan {
  id              String    @id @default(cuid())
  tripId          String    @unique
  generationCount Int       @default(0)
  locale          String    @db.VarChar(10)
  generatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("itinerary_plans")
}

// ─── Transport Segment (Phase 4 — Logistics) ─────────────────────────────

model TransportSegment {
  id              String    @id @default(cuid())
  tripId          String
  segmentOrder    Int       @default(0)

  // Type: "flight" | "bus" | "train" | "car" | "ferry" | "other"
  transportType   String    @db.VarChar(20)

  // Route
  departurePlace  String?   @db.VarChar(150)
  arrivalPlace    String?   @db.VarChar(150)

  // Times
  departureAt     DateTime?
  arrivalAt       DateTime?

  // Details
  provider        String?   @db.VarChar(100)
  bookingCodeEnc  String?   @db.Text
  estimatedCost   Decimal?  @db.Decimal(10, 2)
  currency        String?   @db.VarChar(3)
  notes           String?   @db.VarChar(500)

  // Trip direction
  isReturn        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, segmentOrder])
  @@index([tripId, isReturn])
  @@map("transport_segments")
}

// ─── Accommodation (Phase 4 — Logistics) ─────────────────────────────────

model Accommodation {
  id                String    @id @default(cuid())
  tripId            String

  // Type: "hotel" | "hostel" | "airbnb" | "friends_house" | "camping" | "other"
  accommodationType String    @db.VarChar(20)

  // Details
  name              String?   @db.VarChar(150)
  address           String?   @db.VarChar(300)
  bookingCodeEnc    String?   @db.Text

  // Dates
  checkIn           DateTime?
  checkOut          DateTime?

  // Cost
  estimatedCost     Decimal?  @db.Decimal(10, 2)
  currency          String?   @db.VarChar(3)

  notes             String?   @db.VarChar(500)
  orderIndex        Int       @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, orderIndex])
  @@map("accommodations")
}

// ─── Purchase (PA Packages) ────────────────────────────────────────────────

model Purchase {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId   String    @db.VarChar(50)
  paAmount    Int
  amountCents Int
  currency    String    @default("BRL") @db.VarChar(10)
  status      String    @default("pending") @db.VarChar(20)
  paymentRef  String?   @unique
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("purchases")
}

// ─── AI Governance ──────────────────────────────────────────────────────────

model PromptTemplate {
  id            String   @id @default(cuid())
  slug          String   @unique @db.VarChar(50)
  version       String   @db.VarChar(20)
  modelType     String   @db.VarChar(20)
  systemPrompt  String   @db.Text
  userTemplate  String   @db.Text
  maxTokens     Int      @default(2048)
  cacheControl  Boolean  @default(true)
  isActive      Boolean  @default(true)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug, isActive])
  @@map("prompt_templates")
}

model AiInteractionLog {
  id               String   @id @default(cuid())
  userId           String
  phase            String   @db.VarChar(20)
  provider         String   @db.VarChar(20)
  model            String   @db.VarChar(50)
  promptSlug       String?  @db.VarChar(50)
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  cacheReadTokens  Int      @default(0)
  cacheWriteTokens Int      @default(0)
  estimatedCostUsd Float    @default(0)
  latencyMs        Int      @default(0)
  status           String   @db.VarChar(20)
  errorCode        String?  @db.VarChar(50)
  cacheHit         Boolean  @default(false)
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([phase, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("ai_interaction_logs")
}

model AiKillSwitch {
  id        String   @id @default(cuid())
  phase     String   @unique @db.VarChar(20)
  isEnabled Boolean  @default(false)
  reason    String?  @db.VarChar(500)
  updatedBy String?  @db.VarChar(100)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("ai_kill_switches")
}
