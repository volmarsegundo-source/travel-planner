{
  "name": "travel-planner",
  "version": "0.11.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"if(+process.version.slice(1).split('.')[0]<20){console.error('Node.js 20+ required');process.exit(1)}\"",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next dev --turbopack",
    "prebuild": "prisma generate",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=3072 next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --project=smoke",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "dev:setup": "node scripts/dev-setup.js",
    "dev:check": "node scripts/dev-setup.js --check",
    "dev:reset": "node scripts/dev-setup.js --reset",
    "dev:users": "node scripts/dev-setup.js --users-only",
    "sprint:start": "node scripts/sprint-lifecycle.js start",
    "sprint:review": "node scripts/sprint-lifecycle.js review",
    "sprint:finish": "node scripts/sprint-lifecycle.js finish",
    "sprint:status": "node scripts/sprint-lifecycle.js status",
    "bootstrap": "node scripts/project-bootstrap.js",
    "bootstrap:check": "node scripts/project-bootstrap.js --check",
    "bootstrap:fix": "node scripts/project-bootstrap.js --fix",
    "security": "node scripts/security-audit.js",
    "security:ci": "node scripts/security-audit.js --ci",
    "i18n": "node scripts/i18n-manager.js",
    "i18n:check": "node scripts/i18n-manager.js --check",
    "i18n:sync": "node scripts/i18n-manager.js --sync",
    "test:plan": "node scripts/generate-test-plan.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/prisma-adapter": "^2.7.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.0.0",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.575.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^3.26.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "react-simple-maps": "^3.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "jsdom": "^25.0.1",
    "prisma": "^6.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node --experimental-strip-types prisma/seed.ts"
  }
}
